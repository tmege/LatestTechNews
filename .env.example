# Discord webhooks — create one per channel in Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_AI=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_FINANCE=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_TECH=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_RESUME=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Ollama — local LLM (defaults shown below)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
